        {
          "id": "settled",
          "label": "已有根基，能独立处理多数危机",
          "targets": ["练气后期", "筑基前期"]
        },
        {
          "id": "seasoned",
          "label": "道途已有名声，举手投足皆有威势",
          "targets": ["筑基中期", "筑基后期", "金丹期"]
        }
      ]
    },
    {
